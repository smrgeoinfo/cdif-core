  "schema:datePublished": "2026-04-04",
  "schema:dateModified": "2026-04-04",
  "schema:version": "1",
  "schema:description": "This dataset includes: i) microwave transmission coefficients versus magnetic field and frequency, measured at cryogenic temperatures, ii) python analysis of the microwave transmission coefficients, and iii) a MATLAB script for calculation of microwave component (waveguide and iris) parameters.",
  "schema:keywords": [
    "Engineering",
    "Physics"
  ],
